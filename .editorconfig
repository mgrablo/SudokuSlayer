root = true

[*]
insert_final_newline = true
indent_style = tab
indent_size = 4
ktlint_compose = enabled
ktlint_code_style = android_studio


[{*.kt,*.kts}]
ktlint_compose = enabled
ktlint_function_naming_ignore_when_annotated_with = Composable
ij_kotlin_code_style_defaults = KOTLIN_OFFICIAL
compose_disallow_unstable_collections = true
compose_allowed_composition_locals = LocalSudokuBoardColors, LocalKeyPadColors, LocalExtendedColorScheme, LocalPadding, LocalCatppuccinPalette, LocalHintSheetColors, LocalSudokuTypography

#  Disable wildcard imports entirely
ij_kotlin_name_count_to_use_star_import = 2147483647
ij_kotlin_name_count_to_use_star_import_for_members = 2147483647
ij_kotlin_packages_to_use_import_on_demand = unset
ij_kotlin_allow_trailing_comma_on_call_site = true
ij_kotlin_allow_trailing_comma = true
ij_kotlin_imports_layout = *, java.**, javax.**, kotlin.**, ^
trailing-comma-on-declaration-site = true
trailing-comma-on-call-site = true

[**/build/generated/*/main/**]
ktlint = disabled

[**/test/**]
ktlint_ignore_back_ticked_identifier = true
